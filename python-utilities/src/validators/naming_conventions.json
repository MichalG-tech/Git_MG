{
  "naming_convention": {
    "measures": "^[a-zA-Z][a-zA-Z0-9 _]*$",
    "measure_prefix": "measure_",
    "columns": "^[a-zA-Z][a-zA-Z0-9_]*$",
    "tables": "^(Dim|Fact)[a-zA-Z][a-zA-Z0-9_]*$",
    "roles": "^[A-Za-z ]+$",
    "relationship_names": "^[a-zA-Z][a-zA-Z0-9_]*$"
  },
  "forbidden_patterns": [
    "test",
    "temp",
    "tmp",
    "xxx",
    "delete",
    "debug",
    "hack",
    "fixme",
    "todo"
  ],
  "required_descriptions": true,
  "max_measure_name_length": 100,
  "max_column_name_length": 80,
  "max_table_name_length": 80,
  "star_schema_required": true,
  "enforce_rls": true,
  "allow_implicit_measures": false
}
